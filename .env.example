NODE_ENV="development"
PORT="4000"
DATABASE_URL="postgresql://user:password@localhost:5432/snoutscan?schema=public"
DB_SSL_REJECT_UNAUTHORIZED="true"
JWT_SECRET="replace-with-a-strong-secret"
JWT_EXPIRES_IN="7d"
GOOGLE_CLIENT_ID=""
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_STORAGE_BUCKET=""
UPLOAD_MAX_IMAGE_SIZE_MB="10"
ALLOW_ANONYMOUS_UPLOADS="false"
BIOMETRIC_ML_BASE_URL="http://127.0.0.1:8000"
BIOMETRIC_MATCH_THRESHOLD="0.8"
